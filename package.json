{
  "name": "haven-space",
  "version": "1.0.0",
  "devDependencies": {
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@eslint/eslintrc": "3.3.5",
    "@tailwindcss/postcss": "^4.2.2",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.2.5",
    "prettier-plugin-prisma": "^5.0.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.0.0",
    "typescript": "^5.6.3",
    "vercel": "^50.34.2"
  },
  "packageManager": "bun@1.1.0",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "dev:full": "turbo run dev --filter=@havenspace/public --filter=@havenspace/api-server --filter=@havenspace/boarder --filter=@havenspace/landlord --filter=@havenspace/admin",
    "dev:boarder": "turbo run dev --filter=@havenspace/public --filter=@havenspace/api-server --filter=@havenspace/boarder",
    "dev:landlord": "turbo run dev --filter=@havenspace/public --filter=@havenspace/api-server --filter=@havenspace/landlord",
    "dev:admin": "turbo run dev --filter=@havenspace/public --filter=@havenspace/api-server --filter=@havenspace/admin",
    "dev:public": "turbo run dev --filter=@havenspace/public --filter=@havenspace/api-server",
    "build": "turbo run build",
    "build:all": "turbo run build --filter=@havenspace/public --filter=@havenspace/api-server --filter=@havenspace/boarder --filter=@havenspace/landlord --filter=@havenspace/admin",
    "build:boarder": "turbo run build --filter=@havenspace/boarder",
    "build:landlord": "turbo run build --filter=@havenspace/landlord",
    "build:admin": "turbo run build --filter=@havenspace/admin",
    "build:public": "turbo run build --filter=@havenspace/public",
    "dev:bun": "turbo run dev -- --bun",
    "build:bun": "turbo run build -- --bun",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:generate": "turbo run db:generate",
    "db:push": "turbo run db:push",
    "db:studio": "turbo run db:studio",
    "db:seed": "turbo run db:seed",
    "db:migrate": "bun --filter @havenspace/database db:migrate",
    "prepare": "husky",
    "api:dev": "bun --filter @havenspace/api-server dev",
    "api:build": "bun --filter @havenspace/api-server build",
    "public:dev": "bun --filter @havenspace/public dev",
    "public:build": "bun --filter @havenspace/public build",
    "admin:dev": "bun --filter @havenspace/admin dev",
    "admin:build": "bun --filter @havenspace/admin build",
    "boarder:dev": "bun --filter @havenspace/boarder dev",
    "boarder:build": "bun --filter @havenspace/boarder build",
    "landlord:dev": "bun --filter @havenspace/landlord dev",
    "landlord:build": "bun --filter @havenspace/landlord build",
    "check:all": "bun run lint && bun run typecheck && bun run format:check",
    "docker:up": "docker-compose up -d",
    "docker:dev": "docker-compose -f docker-compose.dev.yml up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:build:api": "docker build -f apps/server/Dockerfile -t havenspace-api .",
    "docker:clean": "docker system prune -f",
    "deploy:vercel": "bun scripts/deploy-vercel.ts",
    "deploy:vercel:public": "cd apps/(public) && vercel --prod",
    "deploy:vercel:admin": "cd apps/admin && vercel --prod",
    "deploy:vercel:boarder": "cd apps/boarder && vercel --prod",
    "deploy:vercel:landlord": "cd apps/landlord && vercel --prod",
    "deploy:vercel:api": "cd apps/server && vercel --prod",
    "vercel:build": "vercel build",
    "vercel:build:prod": "vercel build --prod",
    "vercel:build:public": "cd apps/(public) && vercel build",
    "vercel:build:admin": "cd apps/admin && vercel build",
    "vercel:build:boarder": "cd apps/boarder && vercel build",
    "vercel:build:landlord": "cd apps/landlord && vercel build",
    "vercel:build:api": "cd apps/server && vercel build"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "zod": "4.3.6"
  }
}
