{
  "name": "bhms",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "dev:full": "turbo run dev --filter=@bhms/public --filter=@bhms/api-server --filter=@bhms/boarder --filter=@bhms/landlord --filter=@bhms/admin",
    "dev:boarder": "turbo run dev --filter=@bhms/public --filter=@bhms/api-server --filter=@bhms/boarder",
    "dev:landlord": "turbo run dev --filter=@bhms/public --filter=@bhms/api-server --filter=@bhms/landlord",
    "dev:admin": "turbo run dev --filter=@bhms/public --filter=@bhms/api-server --filter=@bhms/admin",
    "dev:public": "turbo run dev --filter=@bhms/public --filter=@bhms/api-server",
    "build": "turbo run build",
    "build:all": "turbo run build --filter=@bhms/public --filter=@bhms/api-server --filter=@bhms/boarder --filter=@bhms/landlord --filter=@bhms/admin",
    "build:boarder": "turbo run build --filter=@bhms/boarder",
    "build:landlord": "turbo run build --filter=@bhms/landlord",
    "build:admin": "turbo run build --filter=@bhms/admin",
    "build:public": "turbo run build --filter=@bhms/public",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:push": "turbo run db:push",
    "db:studio": "turbo run db:studio",
    "db:seed": "turbo run db:seed",
    "db:migrate": "bun --filter @bhms/database db:migrate",
    "prepare": "husky",
    "api:dev": "bun --filter @bhms/api-server dev",
    "api:build": "bun --filter @bhms/api-server build",
    "public:dev": "bun --filter @bhms/public dev",
    "public:build": "bun --filter @bhms/public build",
    "admin:dev": "bun --filter @bhms/admin dev",
    "admin:build": "bun --filter @bhms/admin build",
    "boarder:dev": "bun --filter @bhms/boarder dev",
    "boarder:build": "bun --filter @bhms/boarder build",
    "landlord:dev": "bun --filter @bhms/landlord dev",
    "landlord:build": "bun --filter @bhms/landlord build",
    "check:all": "bun run lint && bun run typecheck && bun run format:check",
    "docker:up": "docker-compose up -d",
    "docker:dev": "docker-compose -f docker-compose.dev.yml up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:build:api": "docker build -f apps/server/Dockerfile -t bhms-api .",
    "docker:clean": "docker system prune -f"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@eslint/eslintrc": "2.1.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.2.5",
    "prettier-plugin-prisma": "^5.0.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "packageManager": "bun@1.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
