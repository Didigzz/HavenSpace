# Root Environment Variables Example
# Copy this to .env and update with your values

# ============================================
# DATABASE CONFIGURATION
# ============================================
DATABASE_URL="postgresql://postgres:password@localhost:5432/boarding_house_db?schema=public"

# ============================================
# DATABASE SEED (Development Only)
# ============================================
# Default credentials for seed script - CHANGE IN PRODUCTION
SEED_USER_EMAIL="landlord@havenspace.com"
SEED_USER_PASSWORD="YourSecurePassword123!"
SEED_USER_NAME="John Landlord"

# ============================================
# AUTHENTICATION (NextAuth.js)
# ============================================
NEXTAUTH_SECRET="your-secret-key-here-change-in-production-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# Optional: OAuth Providers
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ============================================
# API SERVER
# ============================================
API_URL="http://localhost:3006"

# ============================================
# WEB APPLICATIONS
# ============================================
# Public Platform (Marketplace)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# API Server URL for client-side calls
NEXT_PUBLIC_API_URL="http://localhost:3006"

# ============================================
# REDIS (Caching & Sessions)
# ============================================
REDIS_URL="redis://localhost:6379"

# ============================================
# CLOUD STORAGE (GCP)
# ============================================
GCP_PROJECT_ID=""
GCP_BUCKET_NAME=""
GCP_SERVICE_ACCOUNT_KEY=""

# ============================================
# EMAIL CONFIGURATION (SMTP)
# ============================================
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@localhost"

# ============================================
# PAYMENT PROCESSING (Stripe)
# ============================================
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ============================================
# MAP SERVICES
# ============================================
NEXT_PUBLIC_MAPBOX_TOKEN=""
GOOGLE_MAPS_API_KEY=""

# ============================================
# ANALYTICS & MONITORING
# ============================================
NEXT_PUBLIC_ANALYTICS_ID=""
SENTRY_DSN=""

# ============================================
# FILE UPLOAD
# ============================================
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES="image/jpeg,image/png,image/webp"

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000

# ============================================
# SECURITY
# ============================================
CORS_ORIGIN="http://localhost:3000,http://localhost:3002,http://localhost:3004,http://localhost:3005"
CSRF_SECRET="generate-secure-random-string"

# ============================================
# FEATURE FLAGS
# ============================================
ENABLE_REGISTRATION=true
ENABLE_LANDLORD_APPLICATION=true
ENABLE_BOOKING_SYSTEM=true
ENABLE_PAYMENT_SYSTEM=true
ENABLE_MESSAGING=true

# ============================================
# LOGGING
# ============================================
LOG_LEVEL="info"
